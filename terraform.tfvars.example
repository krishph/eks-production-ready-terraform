aws_region   = "us-east-1"
environment  = "dev"
project_name = "eks-starter"

cluster_version = "1.31"

availability_zones = [
  "us-east-1a",
  "us-east-1b"
]

public_subnets = [
  "10.0.1.0/24",
  "10.0.2.0/24"
]

private_subnets = [
  "10.0.11.0/24",
  "10.0.12.0/24"
]

node_instance_types = ["t3.medium"]
node_desired_size   = 2
node_min_size       = 1
node_max_size       = 3

# Optional: add your IAM user or role ARN so you can administer the cluster
platform_admin_principal_arns = [
  "arn:aws:iam::123456789012:user/your-admin-user"
]
